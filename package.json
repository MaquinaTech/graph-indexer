{
    "name": "graph-indexer",
    "version": "1.0.0",
    "description": "Zero-DB, Air-gapped, In-Memory Graph Indexer MCP Server with Hybrid RRF Search and Cross-Language Topology",
    "type": "module",
    "main": "core-engine.mjs",
    "exports": {
        ".": "./core-engine.mjs"
    },
    "bin": {
        "idx-index": "./indexer.mjs",
        "idx-watch": "./watch-daemon.mjs",
        "idx-mcp": "./mcp-server.mjs"
    },
    "files": [
        "*.mjs",
        "PROMPT.md",
        "README.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MaquinaTech/graph-indexer.git"
    },
    "scripts": {
        "start": "node ./mcp-server.mjs",
        "test": "node tests/eval-harness.mjs --index ./code-index.json",
        "mcp:index": "node indexer.mjs --repo .",
        "mcp:watch": "node watch-daemon.mjs",
        "mcp:start": "node mcp-server.mjs"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "1.29.0",
        "chokidar": "5.0.0",
        "ignore": "5.3.2",
        "tree-sitter": "0.21.1",
        "tree-sitter-css": "0.21.1",
        "tree-sitter-go": "0.21.0",
        "tree-sitter-javascript": "0.21.4",
        "tree-sitter-php": "0.23.1",
        "tree-sitter-python": "0.21.0",
        "tree-sitter-rust": "0.21.0",
        "tree-sitter-typescript": "0.21.2",
        "zod": "3.23.8"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "indexer",
        "ast",
        "tree-sitter",
        "rag",
        "hybrid-search",
        "rrf",
        "call-graph",
        "ollama"
    ],
    "author": {
        "name": "MaquinaTech",
        "url": "https://github.com/MaquinaTech",
        "email": "nicolopezdelerma@gmail.com"
    },
    "license": "GPL-3.0-only",
    "engines": {
        "node": ">=18.0.0"
    },
    "bugs": {
        "url": "https://github.com/MaquinaTech/graph-indexer/issues"
    },
    "optionalDependencies": {
        "hnswlib-node": "^3.0.0"
    }
}